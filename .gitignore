# Python cache and tooling
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/

# Local Python environment
/venv/

# Frontend dependencies and build output
/frontend/node_modules/
/frontend/dist/
/frontend/.vite/

# Environment variables and secrets
.env
.env.*
!.env.example
!.env.*.example
!frontend/.env.example
!frontend/.env.*.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# OS and editor files
.DS_Store
Thumbs.db
*.swp
*.swo

# Spark / Hadoop local runtime files
metastore_db/
spark-warehouse/
derby.log
_temporary/
_SUCCESS
*.crc
*.tmp

# Pipeline data generated locally
/data/processed/

# Raw TLC data is ignored by default, except the selected project dataset.
/data/raw/*
!/data/raw/
!/data/raw/yellow_tripdata_2021-*.parquet
!/data/raw/yellow_tripdata_2022-*.parquet
!/data/raw/yellow_tripdata_2023-*.parquet
!/data/raw/yellow_tripdata_2024-*.parquet

# Generated analytics, forecast, model, and Spark package artifacts
/outputs/
/dist/
/cleaned_sample.csv
/src/visualization/dashboard/data/
*.pkl
*.pickle
*.joblib
